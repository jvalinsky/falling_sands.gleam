    {
      "id": 6,
      "change_id": "a68ff646-0958-446c-9796-0d40f32b48a0",
      "node_type": "option",
      "title": "Gleam + Margolus + Sparse Grid for functional cellular automata",
      "description": null,
      "status": "completed",
      "created_at": "2026-05-26T12:36:16.678883-04:00",
      "updated_at": "2026-05-26T12:38:12.118527-04:00",
      "metadata_json": "{\"branch\":\"main\",\"confidence\":100,\"prompt\":\"Design decision: build the falling sand simulator using Gleam's functional paradigm with Margolus neighbourhoods (parallelizable 2x2 block processing) and a Dict-based sparse grid (air cells implicit, only non-air stored). Competing approach would be mutable arrays in JS but that sacrifices type safety and functional purity.\"}"
    },
    {
      "id": 7,
      "change_id": "460b7d0a-b77b-4a54-99e3-02e461997a3d",
      "node_type": "decision",
      "title": "Gleam + Dict-based sparse grid + Margolus 2x2 blocks",
      "description": null,
      "status": "completed",
      "created_at": "2026-05-26T12:36:19.904036-04:00",
      "updated_at": "2026-05-26T12:38:12.129153-04:00",
      "metadata_json": "{\"branch\":\"main\",\"confidence\":100,\"prompt\":\"Chose Gleam with Dict-based sparse grid and Margolus neighbourhoods over mutable arrays. This gives us type safety, particle conservation by construction (blocks are closed systems), and parallelizable physics.\"}"
    },
